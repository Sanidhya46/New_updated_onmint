    {
      "name": "Ride Request Management",
      "item": [
        {
          "name": "Get All Ride Requests",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.length > 0) {",
                  "        pm.collectionVariables.set('RIDE_REQUEST_ID', response.data[0]._id);",
                  "        if (response.data[0].patient && response.data[0].patient._id) {",
                  "            pm.collectionVariables.set('PATIENT_ID', response.data[0].patient._id);",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/ambulance/requests?page=1&limit=20",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "ambulance",
                "requests"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "status",
                  "value": "pending",
                  "disabled": true
                }
