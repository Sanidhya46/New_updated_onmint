      "name": "Authentication",
      "item": [
        {
          "name": "Register Blood Bank",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.accessToken) {",
                  "        pm.collectionVariables.set('BLOODBANK_TOKEN', response.data.accessToken);",
                  "    }",
                  "    if (response.data && response.data.user && response.data.user._id) {",
                  "        pm.collectionVariables.set('BLOODBANK_ID', response.data.user._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"LifeSaver Blood Bank\",\n  \"email\": \"lifesaver.bloodbank@healthcare.com\",\n  \"password\": \"SecurePass123!\",\n  \"phone\": \"+1234567898\",\n  \"role\": \"bloodbank\",\n  \"address\": {\n    \"street\": \"789 Medical Center Drive\",\n    \"city\": \"Houston\",\n    \"state\": \"TX\",\n    \"zipCode\": \"77001\",\n    \"country\": \"USA\"\n  },\n  \"location\": {\n    \"type\": \"Point\",\n    \"coordinates\": [-95.3698, 29.7604]\n  },\n  \"bankName\": \"LifeSaver Blood Bank\",\n  \"licenseNumber\": \"BB-TX-567890\",\n  \"emergencyContact\": \"+1234567899\",\n  \"operatingHours\": {\n    \"open\": \"00:00\",\n    \"close\": \"23:59\"\n  },\n  \"bloodStock\": [\n    {\n      \"bloodGroup\": \"A+\",\n      \"unitsAvailable\": 50,\n      \"lastUpdated\": \"2026-04-11T10:00:00.000Z\"\n    },\n    {\n      \"bloodGroup\": \"A-\",\n      \"unitsAvailable\": 25,\n      \"lastUpdated\": \"2026-04-11T10:00:00.000Z\"\n    },\n    {\n      \"bloodGroup\": \"B+\",\n      \"unitsAvailable\": 40,\n      \"lastUpdated\": \"2026-04-11T10:00:00.000Z\"\n    },\n    {\n      \"bloodGroup\": \"B-\",\n      \"unitsAvailable\": 20,\n      \"lastUpdated\": \"2026-04-11T10:00:00.000Z\"\n    },\n    {\n      \"bloodGroup\": \"AB+\",\n      \"unitsAvailable\": 15,\n      \"lastUpdated\": \"2026-04-11T10:00:00.000Z\"\n    },\n    {\n      \"bloodGroup\": \"AB-\",\n      \"unitsAvailable\": 10,\n      \"lastUpdated\": \"2026-04-11T10:00:00.000Z\"\n    },\n    {\n      \"bloodGroup\": \"O+\",\n      \"unitsAvailable\": 60,\n      \"lastUpdated\": \"2026-04-11T10:00:00.000Z\"\n    },\n    {\n      \"bloodGroup\": \"O-\",\n      \"unitsAvailable\": 30,\n      \"lastUpdated\": \"2026-04-11T10:00:00.000Z\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Register a new blood bank with initial blood stock inventory for all blood groups"
          },
          "response": []
        },
