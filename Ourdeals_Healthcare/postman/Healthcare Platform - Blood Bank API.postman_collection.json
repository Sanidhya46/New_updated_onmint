    {
      "name": "Blood Request Management",
      "item": [
        {
          "name": "Get All Requests",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.length > 0) {",
                  "        pm.collectionVariables.set('REQUEST_ID', response.data[0]._id);",
                  "        if (response.data[0].patient && response.data[0].patient._id) {",
                  "            pm.collectionVariables.set('PATIENT_ID', response.data[0].patient._id);",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/bloodbank/requests?page=1&limit=20",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "bloodbank",
                "requests"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "status",
                  "value": "pending",
                  "disabled": true
                }
              ]
            },
            "description": "Get all blood requests with optional status filter and pagination"
          },
          "response": []
        },
