        {
          "name": "Register Pharmacist",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.accessToken) {",
                  "        pm.collectionVariables.set('PHARMACIST_TOKEN', response.data.accessToken);",
                  "    }",
                  "    if (response.data && response.data.user && response.data.user._id) {",
                  "        pm.collectionVariables.set('PHARMACIST_ID', response.data.user._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"MediCare Pharmacy\",\n  \"email\": \"medicare.pharmacy@healthcare.com\",\n  \"password\": \"SecurePass123!\",\n  \"phone\": \"+1234567892\",\n  \"role\": \"pharmacist\",\n  \"address\": {\n    \"street\": \"789 Health Street\",\n    \"city\": \"New York\",\n    \"state\": \"NY\",\n    \"zipCode\": \"10001\",\n    \"country\": \"USA\"\n  },\n  \"location\": {\n    \"type\": \"Point\",\n    \"coordinates\": [-73.9352, 40.7306]\n  },\n  \"pharmacyName\": \"MediCare Pharmacy\",\n  \"licenseNumber\": \"PHARM-NY-789012\",\n  \"deliveryTimes\": [\"30min\", \"1hr\", \"same_day\"],\n  \"minimumOrderAmount\": 10,\n  \"deliveryFee\": 5,\n  \"operatingHours\": {\n    \"open\": \"08:00\",\n    \"close\": \"22:00\"\n  }\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Register a new pharmacist account with pharmacy details, delivery options, and operating hours"
          },
          "response": []
        },
