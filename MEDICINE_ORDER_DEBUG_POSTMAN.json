{
  "info": {
    "name": "Medicine Order Debug Collection",
    "description": "Debug medicine order system - from creation to pharmacist visibility",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "patientToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "pharmacistToken", 
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Patient Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    pm.collectionVariables.set('patientToken', response.data.token);",
              "    console.log('Patient token saved:', response.data.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"patient@test.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "2. Pharmacist Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    pm.collectionVariables.set('pharmacistToken', response.data.token);",
              "    console.log('Pharmacist token saved:', response.data.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"pharmacist@test.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "3. Create Medicine Order (Patient)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    const response = pm.response.json();",
              "    pm.collectionVariables.set('orderId', response.data._id);",
              "    console.log('Order created with ID:', response.data._id);",
              "    console.log('Order status:', response.data.status);",
              "    console.log('Service type:', response.data.serviceType);",
              "} else {",
              "    console.log('Order creation failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{patientToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"serviceType\": \"pharmacist\",\n  \"description\": \"Test medicine order: Paracetamol (2x), Cough Syrup (1x). Total: ₹150.00\",\n  \"medicines\": [\n    {\n      \"medicineId\": \"60f1b2b3c4d5e6f7a8b9c0d1\",\n      \"quantity\": 2\n    },\n    {\n      \"medicineId\": \"60f1b2b3c4d5e6f7a8b9c0d2\",\n      \"quantity\": 1\n    }\n  ],\n  \"address\": \"Test Address, Mumbai, Maharashtra - 400001\",\n  \"coordinates\": [72.8777, 19.0760],\n  \"urgency\": \"medium\",\n  \"isEmergency\": false,\n  \"notes\": \"Payment method: Cash on Delivery. 3 items ordered.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/realtime/create",
          "host": ["{{baseUrl}}"],
          "path": ["realtime", "create"]
        }
      }
    },
    {
      "name": "4. Get Pending Orders (Pharmacist)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    const orders = response.data || [];",
              "    console.log('Total pending orders:', orders.length);",
              "    ",
              "    const orderId = pm.collectionVariables.get('orderId');",
              "    const ourOrder = orders.find(order => order._id === orderId);",
              "    ",
              "    if (ourOrder) {",
              "        console.log('✅ Our order found in pending list!');",
              "        console.log('Order details:', JSON.stringify(ourOrder, null, 2));",
              "    } else {",
              "        console.log('❌ Our order NOT found in pending list!');",
              "        console.log('Available orders:', orders.map(o => ({",
              "            id: o._id,",
              "            status: o.status,",
              "            serviceType: o.serviceType",
              "        })));",
              "    }",
              "} else {",
              "    console.log('Failed to get pending orders:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{pharmacistToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/pharmacist/orders/pending?page=1&limit=20",
          "host": ["{{baseUrl}}"],
          "path": ["pharmacist", "orders", "pending"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "20"
            }
          ]
        }
      }
    },
    {
      "name": "5. Get Orders with Status=Requested (Pharmacist)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    const orders = response.data || [];",
              "    console.log('Total requested orders:', orders.length);",
              "    ",
              "    const orderId = pm.collectionVariables.get('orderId');",
              "    const ourOrder = orders.find(order => order._id === orderId);",
              "    ",
              "    if (ourOrder) {",
              "        console.log('✅ Our order found in requested list!');",
              "    } else {",
              "        console.log('❌ Our order NOT found in requested list!');",
              "    }",
              "} else {",
              "    console.log('Failed to get requested orders:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{pharmacistToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/pharmacist/orders?status=requested&page=1&limit=20",
          "host": ["{{baseUrl}}"],
          "path": ["pharmacist", "orders"],
          "query": [
            {
              "key": "status",
              "value": "requested"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "20"
            }
          ]
        }
      }
    },
    {
      "name": "6. Get Order Details (Patient)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    console.log('Order status:', response.data.status);",
              "    console.log('Service type:', response.data.serviceType);",
              "    console.log('Has acceptedProvider:', !!response.data.acceptedProvider);",
              "    console.log('Medicines count:', response.data.medicines?.length || 0);",
              "} else {",
              "    console.log('Failed to get order details:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{patientToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/realtime/booking/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["realtime", "booking", "{{orderId}}"]
        }
      }
    },
    {
      "name": "7. Accept Order (Pharmacist)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    console.log('✅ Order accepted successfully!');",
              "} else {",
              "    console.log('❌ Failed to accept order:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{pharmacistToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/pharmacist/orders/{{orderId}}/accept",
          "host": ["{{baseUrl}}"],
          "path": ["pharmacist", "orders", "{{orderId}}", "accept"]
        }
      }
    }
  ]
}